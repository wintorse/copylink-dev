{
  "name": "copylink.dev",
  "version": "1.8.0",
  "description": "Browser extension that provides shortcuts to copy links. On supported sites, it creates Slack emoji-enhanced links.",
  "homepage": "https://github.com/wintorse/copylink-dev#readme",
  "bugs": {
    "url": "https://github.com/wintorse/copylink-dev/issues"
  },
  "license": "MIT",
  "author": "wintorse",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wintorse/copylink-dev.git"
  },
  "type": "module",
  "main": "src/background.ts",
  "scripts": {
    "build": "tsc && vite build --emptyOutDir && vite build --config vite.content.config.js",
    "build-firefox": "tsc && vite build --emptyOutDir --minify false --mode firefox && vite build --config vite.content.config.js --minify false --mode firefox",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/tsconfig.json",
    "test": "pnpm build && playwright test",
    "test:headed": "pnpm build && playwright test --headed",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "happy-dom": "^20.9.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
